PORT=3001
QLIK_HOST=https://your-qlik-cloud-host.example.com
QLIK_ASSISTANT_ID=your-default-assistant-id
CLOUD_ASSISTANT_ID=your-cloud-assistant-id
QLIK_WEB_INTEGRATION_ID=your-web-integration-id

# Opcion 1: pega aqui un API key/token valido
QLIK_TOKEN=replace-with-a-valid-token

# Opcion 2: OAuth server-side
QLIK_OAUTH_CLIENT_ID=your-oauth-client-id
QLIK_OAUTH_CLIENT_SECRET=your-oauth-client-secret
QLIK_OAUTH_REDIRECT_URI=http://127.0.0.1:5500/auth/callback

BACKEND_ORIGIN=http://localhost:3001
FRONTEND_ORIGIN=http://127.0.0.1:5500
BEPYME_QLIK_SPACE_ID=your-space-id
BEPYME_QLIK_APP_ID=your-app-id